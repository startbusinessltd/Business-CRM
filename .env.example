# Browser origin of the Business CRM Angular app (signup / login / trial open here; APIs run via that app).
# Production marketing builds default to the hosted CRM shell URL — override for staging if needed.
# VITE_CRM_APP_ORIGIN=https://your-crm-host.example
# Local: marketing on :5180, CRM shell on :4200
# VITE_CRM_APP_ORIGIN=http://localhost:4200

# StartBusiness API base (contact form → operation/public/contact/book). Trailing slash optional.
# Dev default: direct gateway http://localhost:8013/api/ (same as startbusinessltd-ui environment.apiUrl)
# Embedded in Angular shell: parent sends SET_API_BASE from environment.apiUrl automatically.
# Optional: link contact submissions to a WEBSITE row (Website Leads). Overrides domain lookup.
# VITE_CONTACT_WEBSITE_ID=123
# VITE_CONTACT_WEBSITE_DOMAIN=businesscrm.co.in
# VITE_API_BASE=https://api.startbusiness.ltd/api/
# VITE_API_BASE=http://localhost:8013/api/
